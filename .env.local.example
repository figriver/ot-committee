# Copy to .env.local and fill in from the Supabase project (ot-committee, ref aduhjzhvppkzjslzovwk).
# Get values: Supabase Dashboard -> Project Settings -> API
# NEVER commit .env.local (it is gitignored).

# Public project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://aduhjzhvppkzjslzovwk.supabase.co

# Anon key — safe to expose. Used by the cookie-bound auth client (login,
# magic-link verify, session) in middleware and server code. (slice 1b)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key — SERVER ONLY. Never expose to the browser, never prefix with NEXT_PUBLIC_.
# ALL board/member DATA access runs server-side with this key (RLS is on; the
# anon/user client would return zero rows). Auth session uses the anon key above.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Base URL used to build the magic-link redirect (emailRedirectTo). Prod uses the
# Vercel URL; locally this is http://localhost:3000. (slice 1b)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
